{
    "name": "voice-type-cli",
    "version": "1.1.4",
    "description": "System-wide Speech To Text dictation tool",
    "main": "dist/index.js",
    "type": "module",
    "os": [
        "linux"
    ],
    "bin": {
        "voice-type": "bin/voice-type"
    },
    "files": [
        "bin",
        "dist",
        "assets"
    ],
    "scripts": {
        "dev": "bun --watch src/index.ts",
        "start": "bun run src/index.ts",
        "build": "bun build src/index.ts --outdir dist --target node",
        "compile-binary": "bun build src/index.ts --compile --outfile build/voice-type",
        "prepublishOnly": "bun run build"
    },
    "dependencies": {
        "dbus-next": "^0.10.2",
        "express": "^5.2.1",
        "puppeteer-core": "^24.39.1",
        "x11": "^2.3.0"
    },
    "devDependencies": {
        "@types/express": "^5.0.6",
        "bun": "^1.3.11",
        "bun-types": "^1.3.11",
        "prettier": "^3.8.1",
        "typescript": "^5.9.3"
    }
}