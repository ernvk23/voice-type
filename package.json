{
    "name": "wraith",
    "version": "1.0.0",
    "main": "src/index.ts",
    "dependencies": {
        "bun": "^1.3.11",
        "dbus-next": "^0.10.2",
        "express": "^5.2.1",
        "puppeteer-core": "^24.39.1"
    },
    "description": "system-wide Speech To Text (STT)",
    "scripts": {
        "dev": "bun --watch src/index.ts",
        "start": "bun run src/index.ts",
        "build": "bun build src/index.ts --outdir dist --target node",
        "compile": "bun build src/index.ts --compile --outfile transcribe-binary"
    },
    "type": "module",
    "devDependencies": {
        "@types/express": "^5.0.6",
        "bun-types": "^1.3.11",
        "prettier": "^3.8.1",
        "typescript": "^5.9.3"
    }
}