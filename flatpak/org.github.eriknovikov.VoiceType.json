{
    "app-id": "org.github.eriknovikov.VoiceType",
    "runtime": "org.freedesktop.Platform",
    "runtime-version": "24.08",
    "sdk": "org.freedesktop.Sdk",
    "sdk-extensions": [
        "org.freedesktop.Sdk.Extension.golang"
    ],
    "base": "org.electronjs.Electron2.BaseApp",
    "base-version": "24.08",
    "command": "voice-type",
    "finish-args": [
        "--share=ipc",
        "--socket=x11",
        "--socket=wayland",
        "--device=dri",
        "--share=network",
        "--socket=pulseaudio",
        "--talk-name=org.freedesktop.Notifications",
        "--talk-name=org.freedesktop.Flatpak",
        "--device=all",
        "--filesystem=xdg-config",
        "--filesystem=xdg-cache"
    ],
    "modules": [
        {
            "name": "dotool",
            "buildsystem": "simple",
            "build-options": {
                "build-args": [
                    "--share=network"
                ],
                "append-path": "/usr/lib/sdk/golang/bin",
                "env": {
                    "GOPATH": "/run/build/dotool/go",
                    "CGO_ENABLED": "1"
                }
            },
            "build-commands": [
                "go build -v -o /app/bin/dotool .",
                "ln -s dotool /app/bin/dotoolc",
                "ln -s dotool /app/bin/dotoold"
            ],
            "post-install": [
                "chmod -R u+w ."
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://git.sr.ht/~geb/dotool",
                    "tag": "1.6"
                }
            ]
        },
        {
            "name": "bun",
            "buildsystem": "simple",
            "build-commands": [
                "mv bun /app/bin/",
                "ln -s bun /app/bin/bunx"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://github.com/oven-sh/bun/releases/download/bun-v1.3.11/bun-linux-x64.zip",
                    "sha256": "8611ba935af886f05a6f38740a15160326c15e5d5d07adef966130b4493607ed",
                    "strip-components": 1,
                    "only-arches": [
                        "x86_64"
                    ]
                },
                {
                    "type": "archive",
                    "url": "https://github.com/oven-sh/bun/releases/download/bun-v1.3.11/bun-linux-aarch64.zip",
                    "sha256": "d13944da12a53ecc74bf6a720bd1d04c4555c038dfe422365356a7be47691fdf",
                    "strip-components": 1,
                    "only-arches": [
                        "aarch64"
                    ]
                }
            ]
        },
        {
            "name": "voice-type",
            "buildsystem": "simple",
            "build-options": {
                "build-args": [
                    "--share=network"
                ]
            },
            "build-commands": [
                "sed -i 's|/usr/bin/google-chrome-stable|/app/bin/host-chrome|g' src/daemon.ts",
                "bun install",
                "bun build src/index.ts --compile --outfile /app/bin/voice-type-bin",
                "echo '#!/bin/bash' > /app/bin/voice-type",
                "echo 'exec /app/bin/voice-type-bin \"$@\"' >> /app/bin/voice-type",
                "echo '#!/bin/bash' > /app/bin/host-chrome",
                "echo 'exec flatpak-spawn --host google-chrome-stable \"$@\"' >> /app/bin/host-chrome",
                "chmod +x /app/bin/voice-type",
                "chmod +x /app/bin/host-chrome",
                "install -Dm644 assets/sounds/start.oga /app/share/sounds/voice-type/start.oga",
                "install -Dm644 assets/sounds/stop.oga /app/share/sounds/voice-type/stop.oga",
                "install -Dm644 flatpak/org.github.eriknovikov.VoiceType.metainfo.xml /app/share/metainfo/org.github.eriknovikov.VoiceType.metainfo.xml",
                "install -Dm644 flatpak/org.github.eriknovikov.VoiceType.desktop /app/share/applications/org.github.eriknovikov.VoiceType.desktop",
                "install -Dm644 flatpak/org.github.eriknovikov.VoiceType.svg /app/share/icons/hicolor/scalable/apps/org.github.eriknovikov.VoiceType.svg"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/eriknovikov/voice-type.git",
                    "tag": "v1.0"
                }
            ]
        }
    ]
}