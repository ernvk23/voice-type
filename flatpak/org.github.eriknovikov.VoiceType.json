{
    "app-id": "org.github.eriknovikov.VoiceType",
    "runtime": "org.freedesktop.Platform",
    "runtime-version": "24.08",
    "sdk": "org.freedesktop.Sdk",
    "sdk-extensions": [
        "org.freedesktop.Sdk.Extension.golang"
    ],
    "base": "org.electronjs.Electron2.BaseApp",
    "base-version": "24.08",
    "command": "voice-type",
    "finish-args": [
        "--share=ipc",
        "--socket=x11",
        "--socket=wayland",
        "--device=dri",
        "--share=network",
        "--socket=pulseaudio",
        "--talk-name=org.freedesktop.Notifications",
        "--talk-name=org.freedesktop.Flatpak",
        "--device=all",
        "--filesystem=xdg-config",
        "--filesystem=xdg-cache"
    ],
    "modules": [
        {
            "name": "dotool",
            "buildsystem": "simple",
            "build-options": {
                "build-args": [
                    "--share=network"
                ],
                "append-path": "/usr/lib/sdk/golang/bin",
                "env": {
                    "GOPATH": "/run/build/dotool/go",
                    "CGO_ENABLED": "1"
                }
            },
            "build-commands": [
                "go build -v -o /app/bin/dotool .",
                "ln -s dotool /app/bin/dotoolc",
                "ln -s dotool /app/bin/dotoold"
            ],
            "post-install": [
                "chmod -R u+w ."
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://git.sr.ht/~geb/dotool",
                    "branch": "master"
                }
            ]
        },
        {
            "name": "bun",
            "buildsystem": "simple",
            "build-options": {
                "build-args": [
                    "--share=network"
                ]
            },
            "build-commands": [
                "curl -fsSL https://bun.sh/install | BUN_INSTALL=/app bash"
            ]
        },
        {
            "name": "voice-type",
            "buildsystem": "simple",
            "build-options": {
                "build-args": [
                    "--share=network"
                ]
            },
            "build-commands": [
                "sed -i 's|/usr/bin/google-chrome|/app/bin/host-browser|g' src/browserLauncher.ts",
                "sed -i 's|/usr/bin/chromium|/app/bin/host-browser|g' src/browserLauncher.ts",
                "bun install",
                "bun build src/index.ts --compile --outfile /app/bin/voice-type-bin",
                "echo '#!/bin/bash' > /app/bin/voice-type",
                "echo 'exec /app/bin/voice-type-bin \"$@\"' >> /app/bin/voice-type",
                "echo '#!/bin/bash' > /app/bin/host-browser",
                "echo 'flatpak-spawn --host which google-chrome &>/dev/null && exec flatpak-spawn --host google-chrome \"$@\"' >> /app/bin/host-browser",
                "echo 'flatpak-spawn --host which chromium &>/dev/null && exec flatpak-spawn --host chromium \"$@\"' >> /app/bin/host-browser",
                "echo 'echo \"No Chrome/Chromium found\"; exit 1' >> /app/bin/host-browser",
                "chmod +x /app/bin/voice-type",
                "chmod +x /app/bin/host-browser",
                "install -Dm644 assets/sounds/start.oga /app/share/sounds/voice-type/start.oga",
                "install -Dm644 assets/sounds/stop.oga /app/share/sounds/voice-type/stop.oga",
                "install -Dm644 flatpak/org.github.eriknovikov.VoiceType.xml /app/share/metainfo/org.github.eriknovikov.VoiceType.metainfo.xml",
                "install -Dm644 flatpak/org.github.eriknovikov.VoiceType.desktop /app/share/applications/org.github.eriknovikov.VoiceType.desktop",
                "install -Dm644 flatpak/org.github.eriknovikov.VoiceType.svg /app/share/icons/hicolor/scalable/apps/org.github.eriknovikov.VoiceType.svg"
            ],
            "sources": [
                {
                    "type": "dir",
                    "path": ".."
                }
            ]
        }
    ]
}